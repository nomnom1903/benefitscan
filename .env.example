# BenefitScan — Environment Variables Template
# ─────────────────────────────────────────────
# 1. Copy this file: cp .env.example .env
# 2. Fill in your values in .env
# 3. NEVER commit .env to git — it contains your API key

# --- AI Provider ---
# Switch between providers here. Only the matching API key is required.
# "anthropic" = Claude API (paid, most accurate)
# "gemini"    = Google Gemini (FREE tier, no credit card — get key at aistudio.google.com)
AI_PROVIDER=gemini

# --- API Keys ---
# Anthropic (paid): https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google Gemini (free): https://aistudio.google.com → Get API Key
GEMINI_API_KEY=your-gemini-key-here

# --- Optional: Server Config ---
# Port the app runs on. Default: 8000
# NOTE for macOS users: port 5000 is taken by AirPlay Receiver. Use 8000 or 8080.
APP_PORT=8000

# Set to "development" for detailed error messages, "production" to hide them
APP_ENV=development

# --- Optional: AI Model ---
# Which Claude model to use for extraction. Opus is most accurate.
# Options: claude-opus-4-5 | claude-sonnet-4-5 | claude-haiku-4-5
# V2 note: you might switch to claude-sonnet-4-5 to reduce cost at scale
CLAUDE_MODEL=claude-opus-4-5
